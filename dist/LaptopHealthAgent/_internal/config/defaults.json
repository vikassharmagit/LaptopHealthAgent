{
  "storage_roots": [
    "%USERPROFILE%\\Downloads",
    "%USERPROFILE%\\Desktop",
    "%USERPROFILE%\\Documents"
  ],
  "protected_paths": [
    "%WINDIR%",
    "%PROGRAMFILES%",
    "%PROGRAMFILES(X86)%",
    "%USERPROFILE%\\OneDrive\\Documents\\LaptopHealthAgent"
  ],
  "process_whitelist": [
    "System",
    "Registry",
    "smss.exe",
    "csrss.exe",
    "wininit.exe",
    "services.exe",
    "lsass.exe",
    "svchost.exe",
    "explorer.exe",
    "dwm.exe",
    "SearchIndexer.exe",
    "OneDrive.exe",
    "Code.exe",
    "WindowsTerminal.exe",
    "powershell.exe",
    "pwsh.exe",
    "python.exe",
    "uvicorn.exe",
    "LaptopHealthAgent.exe"
  ],
  "large_file_mb": 500,
  "old_file_days": 90,
  "scan_max_files_per_root": 3000,
  "duplicate_scan_max_files": 1000,
  "duplicate_hash_max_mb": 200
}
